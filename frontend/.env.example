# Frontend (Vercel) environment variables

# Public URL of this frontend deployment
NEXTAUTH_URL="https://your-frontend.vercel.app"

# Generate a strong secret and set in Vercel
NEXTAUTH_SECRET="replace-with-strong-secret"

# Database used by NextAuth + Prisma in frontend
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Internal API route proxy target (server-side)
AI_SERVICE_URL="https://your-ai-service.onrender.com"

# Public API base for teachers/events/campus map (client-side)
NEXT_PUBLIC_CORE_SERVICE_URL="https://your-core-service.onrender.com"
